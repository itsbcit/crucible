# Add dockerize
ADD https://github.com/jwilder/dockerize/releases/download/v<%= image.vars['dockerize_version'] %>/dockerize-alpine-linux-amd64-v<%= image.vars['dockerize_version'] %>.tar.gz /tmp/dockerize.tar.gz
RUN [ -d /usr/local/bin ] || mkdir -p /usr/local/bin \
 && tar zx -C /usr/local/bin -f /tmp/dockerize.tar.gz dockerize \
 && rm /tmp/dockerize.tar.gz \
 && chown 0:0 /usr/local/bin/dockerize \
 && chmod 0555 /usr/local/bin/dockerize

ENV DOCKERIZE_ENV production
